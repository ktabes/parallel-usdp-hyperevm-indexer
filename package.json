{
  "name": "parallel-usdp-hyperevm-indexer",
  "version": "0.1.0",
  "private": true,
  "description": "Auditable cross-chain indexer and analytics surface for Parallel USDp and sUSDp.",
  "engines": {
    "node": ">=22.11 <26"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node --import tsx scripts/start-service.ts",
    "start:web": "next start",
    "worker:hyperevm-history": "node --import tsx src/workers/hyperevm-history.ts",
    "cli": "node --import tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:fixtures": "vitest run tests/fixtures",
    "test:integration": "vitest run tests/integration",
    "test:network": "vitest run tests/network",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "secrets": "node --import tsx scripts/check-secrets.ts",
    "check": "npm run secrets && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.28.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "^5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    },
    "next": {
      "postcss": "8.5.19"
    }
  }
}
