# PostgreSQL connection used by the API, worker, and migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parallel_usdp

# Optional separate database used by integration tests.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parallel_usdp_test

# HyperEVM mainnet RPC. Never commit a provider key.
HYPEREVM_RPC_URL=https://rpc.example.invalid

# Index only blocks at or below head - FINALITY_LAG.
FINALITY_LAG=5

# Starting log range; the adaptive planner may reduce it.
RPC_LOG_CHUNK_SIZE=5000

# MVP price policy is finalized during protocol discovery.
PRICE_SOURCE=unconfigured

# Finalized state/YPO refresh target in seconds.
REFRESH_INTERVAL_SECONDS=30

# Opt in to tests that call the configured RPC.
RUN_NETWORK_TESTS=0
